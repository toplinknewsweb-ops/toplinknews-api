{
  "name": "toplinknews-api",
  "version": "4.0.0",
  "description": "Top Link News – RSS aggregator API. Serves national, international, all 50 states + DC, and 7 topic pages (sports, economy, technology, betting, diet, wellness, ai).",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev":   "node --watch server.js",
    "lint":  "node --check server.js && echo 'Syntax OK'"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "compression":     "^1.7.4",
    "cors":            "^2.8.5",
    "express":         "^4.19.2",
    "fast-xml-parser": "^4.4.1",
    "helmet":          "^7.1.0"
  },
  "keywords": ["news", "rss", "aggregator", "express", "toplinknews"],
  "license": "ISC"
}
